# Anthropic
ANTHROPIC_API_KEY=sk-ant-...
CLAUDE_MODEL=claude-sonnet-4-6

# Confluence (Atlassian Cloud)
CONFLUENCE_BASE_URL=https://yoursite.atlassian.net/wiki
CONFLUENCE_USER_EMAIL=you@company.com
CONFLUENCE_TOKEN=your-confluence-api-token
CONFLUENCE_SPACE_KEY=ENG

# Docs map location (optional — defaults to config/docs_map.yml)
# DOCS_MAP_PATH=config/docs_map.yml

# Templates directory (optional — defaults to templates/)
# TEMPLATES_DIR=templates
